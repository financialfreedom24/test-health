            {id: 33, category: 'mental', emoji: '🧠', color: '#6366f1', title: '30-Day Mental Reset Plan', desc: 'Because you don\'t need a crisis to deserve better mental health.', headline: 'Ready for a Real Mental Health Reset?', pain: 'You don\'t need a crisis to deserve better mental health. 30 days. One small step. Real transformation.', cta: 'Start My 30-Day Reset 💚'}
        ];

        let currentGuide = null;
        let activeSharePopup = null;

        // Render all guides
        function renderGuides() {
            const categories = {
                'quick-fix': document.getElementById('slider-quick-fix'),
                'conditions': document.getElementById('slider-conditions'),
                'food': document.getElementById('slider-food'),
                'weight': document.getElementById('slider-weight'),
                'mental': document.getElementById('slider-mental')
            };

            guides.forEach(guide => {
                const card = createGuideCard(guide);
                categories[guide.category].appendChild(card);
            });
        }

        // Create guide card
        function createGuideCard(guide) {
            const card = document.createElement('div');
            card.className = 'guide-card';
            card.id = `guide-${guide.id}`;
            card.style.borderLeftColor = guide.color;
            
            card.innerHTML = `
                <div class="card-header">
                    <span class="card-tag" style="background: ${guide.color};">${guide.emoji} ${getCategoryName(guide.category)}</span>
                    <div class="card-icon" style="background: ${guide.color}20; color: ${guide.color};">📄</div>
                </div>
                <h3 class="card-title">${guide.title}</h3>
                <p class="card-desc">${guide.desc}</p>
                <div class="card-actions">
                    <button class="btn-download" style="background: ${guide.color};" onclick="openModal(${guide.id})">⬇ Get Free Guide</button>
                    <button class="btn-share" style="border-color: ${guide.color}; color: ${guide.color};" onclick="toggleShare(event, ${guide.id})">📤 Share</button>
                </div>
                <div class="share-popup" id="share-${guide.id}" onclick="event.stopPropagation()">
                    <div class="share-icons">
                        <a class="share-icon" onclick="shareWhatsApp(${guide.id}); event.stopPropagation();">
                            <div class="share-icon-circle whatsapp">📱</div>
                            <span>WhatsApp</span>
                        </a>
                        <a class="share-icon" onclick="shareFacebook(${guide.id}); event.stopPropagation();">
                            <div class="share-icon-circle facebook">👍</div>
                            <span>Facebook</span>
                        </a>
                        <a class="share-icon" onclick="shareTwitter(${guide.id}); event.stopPropagation();">
                            <div class="share-icon-circle twitter">🐦</div>
                            <span>Twitter</span>
                        </a>
                        <a class="share-icon" onclick="copyLink(${guide.id}); event.stopPropagation();">
                            <div class="share-icon-circle copy-link" id="copy-icon-${guide.id}">📋</div>
                            <span id="copy-text-${guide.id}">Copy Link</span>
                        </a>
                        <a href="https://www.tiktok.com/@health.harbor1" target="_blank" class="share-icon">
                            <div class="share-icon-circle tiktok-share">🎵</div>
                            <span>TikTok</span>
                        </a>
                    </div>
                </div>
            `;
            
            return card;
        }

        function getCategoryName(category) {
            const names = {
                'quick-fix': 'Quick Fix',
                'conditions': 'Condition',
                'food': 'Food & Nutrition',
                'weight': 'Weight & Body',
                'mental': 'Mental Health'
            };
            return names[category];
        }

        // Toggle share popup
        function toggleShare(event, guideId) {
            console.log('Share button clicked for guide:', guideId);
            event.stopPropagation();
            event.preventDefault();
            
            const popup = document.getElementById(`share-${guideId}`);
            console.log('Popup element:', popup);
            
            if (!popup) {
                console.error('Popup not found for guide:', guideId);
                return;
            }
            
            // Close any other open popup
            if (activeSharePopup && activeSharePopup !== popup) {
                activeSharePopup.classList.remove('active');
            }
            
            // Toggle current popup
            const isActive = popup.classList.contains('active');
            if (isActive) {
                popup.classList.remove('active');
                activeSharePopup = null;
                console.log('Popup closed');
            } else {
                popup.classList.add('active');
                activeSharePopup = popup;
                console.log('Popup opened');
            }
        }

        // Close share popup when clicking outside
        document.addEventListener('click', function(e) {
            if (activeSharePopup) {
                // Check if click is outside the popup
                const clickedInsidePopup = activeSharePopup.contains(e.target);
                const clickedShareButton = e.target.closest('.btn-share');
                
                if (!clickedInsidePopup && !clickedShareButton) {
                    console.log('Closing popup - clicked outside');
                    activeSharePopup.classList.remove('active');
                    activeSharePopup = null;
                }
            }
        });

        // Share functions
        function getGuideUrl(guideId) {
            return `https://healthharbor.com/#guide-${guideId}`;
        }

        function shareWhatsApp(guideId) {
            const guide = guides.find(g => g.id === guideId);
            const url = getGuideUrl(guideId);
            const text = `Check out this free health guide: ${guide.title}`;
            window.open(`https://wa.me/?text=${encodeURIComponent(text + ' ' + url)}`, '_blank');
        }

        function shareFacebook(guideId) {
            const url = getGuideUrl(guideId);
            window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`, '_blank');
        }

        function shareTwitter(guideId) {
            const guide = guides.find(g => g.id === guideId);
            const url = getGuideUrl(guideId);
            const text = `Free health guide: ${guide.title}`;
            window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}&via=health.harbor1`, '_blank');
        }

        function copyLink(guideId) {
            const url = getGuideUrl(guideId);
            navigator.clipboard.writeText(url).then(() => {
                const icon = document.getElementById(`copy-icon-${guideId}`);
                const text = document.getElementById(`copy-text-${guideId}`);
                icon.textContent = '✓';
                text.textContent = 'Copied!';
                setTimeout(() => {
                    icon.textContent = '📋';
                    text.textContent = 'Copy Link';
                }, 2000);
            });
        }

        // Modal functions
        function openModal(guideId) {
            const guide = guides.find(g => g.id === guideId);
            currentGuide = guide;
            
            document.getElementById('modalHeader').style.background = guide.color;
            document.getElementById('modalHeadline').textContent = guide.headline;
            document.getElementById('modalPain').textContent = guide.pain;
            document.getElementById('modalSubmit').textContent = guide.cta;
            document.getElementById('modalSubmit').style.background = guide.color;
            
            document.getElementById('modalBody').style.display = 'block';
            document.getElementById('modalSuccess').classList.remove('active');
            document.getElementById('modalForm').reset();
            
            document.getElementById('modalOverlay').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            document.getElementById('modalOverlay').classList.remove('active');
            document.body.style.overflow = '';
        }

        function handleSubmit(event) {
            event.preventDefault();
            const name = event.target[0].value;
            document.getElementById('successMessage').textContent = `Your "${currentGuide.title}" is on its way! Check your inbox. 💚`;
            document.getElementById('modalBody').style.display = 'none';
            document.getElementById('modalSuccess').classList.add('active');
            
            // Here you would send the email and guide info to your backend
            console.log('Form submitted for guide:', currentGuide.id, 'Name:', name, 'Email:', event.target[1].value);
            
            setTimeout(() => {
                closeModal();
            }, 3000);
            
            return false;
        }

        // Close modal on ESC key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeModal();
            }
        });

        // Close modal on overlay click
        document.getElementById('modalOverlay').addEventListener('click', function(e) {
            if (e.target === this) {
                closeModal();
            }
        });

        // Slider functions
        function scrollSlider(category, direction) {
            const slider = document.getElementById(`slider-${category}`);
            const cardWidth = slider.querySelector('.guide-card').offsetWidth + 24; // card width + gap
            slider.scrollBy({ left: direction * cardWidth * 2, behavior: 'smooth' });
        }

        // Update slider arrows visibility
        function updateSliderArrows() {
            const categories = ['quick-fix', 'conditions', 'food', 'weight', 'mental'];
            categories.forEach(category => {
                const slider = document.getElementById(`slider-${category}`);
                const leftArrow = slider.parentElement.querySelector('.slider-arrow.left');
                const rightArrow = slider.parentElement.querySelector('.slider-arrow.right');
                
                if (slider.scrollLeft <= 0) {
                    leftArrow.classList.add('hidden');
                } else {
                    leftArrow.classList.remove('hidden');
                }
                
                if (slider.scrollLeft >= slider.scrollWidth - slider.clientWidth - 10) {
                    rightArrow.classList.add('hidden');
                } else {
                    rightArrow.classList.remove('hidden');
                }
            });
        }

        // Search functionality
        document.getElementById('searchBar').addEventListener('input', function(e) {
            const query = e.target.value.toLowerCase().trim();
            
            if (query === '') {
                // Show all sections and cards
                document.querySelectorAll('.guide-section').forEach(section => {
                    section.style.display = 'block';
                });
                document.querySelectorAll('.guide-card').forEach(card => {
                    card.style.display = 'block';
                });
                document.getElementById('noResults').classList.remove('active');
                return;
            }
            
            let hasResults = false;
            
            guides.forEach(guide => {
                const card = document.getElementById(`guide-${guide.id}`);
                const matchesSearch = guide.title.toLowerCase().includes(query) || 
                                    guide.desc.toLowerCase().includes(query);
                
                if (matchesSearch) {
                    card.style.display = 'block';
                    hasResults = true;
                } else {
                    card.style.display = 'none';
                }
            });
            
            // Hide empty sections
            document.querySelectorAll('.guide-section').forEach(section => {
                const visibleCards = section.querySelectorAll('.guide-card[style="display: block;"]');
                if (visibleCards.length === 0) {
                    section.style.display = 'none';
                } else {
                    section.style.display = 'block';
                }
            });
            
            if (!hasResults) {
                document.getElementById('noResults').classList.add('active');
            } else {
                document.getElementById('noResults').classList.remove('active');
            }
        });

        // Navbar scroll effect
        window.addEventListener('scroll', function() {
            const navbar = document.getElementById('navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });

        // Hamburger menu
        document.getElementById('hamburger').addEventListener('click', function() {
            document.getElementById('mobileMenu').classList.toggle('active');
        });

        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    // Clear search when navigating via category pills
                    if (this.classList.contains('pill')) {
                        document.getElementById('searchBar').value = '';
                        document.querySelectorAll('.guide-section').forEach(section => {
                            section.style.display = 'block';
                        });
                        document.querySelectorAll('.guide-card').forEach(card => {
                            card.style.display = 'block';
                        });
                        document.getElementById('noResults').classList.remove('active');
                    }
                }
                // Close mobile menu
                document.getElementById('mobileMenu').classList.remove('active');
            });
        });

        // Check for hash in URL on page load
        window.addEventListener('load', function() {
            const hash = window.location.hash;
            if (hash && hash.startsWith('#guide-')) {
                const guideId = parseInt(hash.replace('#guide-', ''));
                const card = document.getElementById(`guide-${guideId}`);
                if (card) {
                    setTimeout(() => {
                        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        setTimeout(() => {
                            openModal(guideId);
                        }, 600);
                    }, 500);
                }
            }
        });

        // Initialize
        renderGuides();
        updateSliderArrows();

        // Update arrows on scroll
        document.querySelectorAll('.slider').forEach(slider => {
            slider.addEventListener('scroll', updateSliderArrows);
        });

        // Update arrows on window resize
        window.addEventListener('resize', updateSliderArrows);
    </script>
</body>
</html>
